{
  "name": "@workspace/db",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "generate": "drizzle-kit generate",
    "migrate": "tsx src/migrate.ts",
    "ingest": "tsx src/ingest/index.ts",
    "lint": "eslint",
    "format": "prettier --write \"**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "seed": "tsx src/seed.ts import",
    "seed:export": "tsx src/seed.ts export",
    "verify": "tsx src/verify.ts",
    "setup": "pnpm migrate && pnpm seed"
  },
  "dependencies": {
    "@electric-sql/pglite": "catalog:",
    "@workspace/core": "workspace:*",
    "drizzle-orm": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "drizzle-kit": "catalog:",
    "eslint": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema.ts",
    "./*": "./src/*.ts"
  }
}
