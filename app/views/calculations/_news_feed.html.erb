<section class="mx-auto mt-16 w-full max-w-7xl px-5 sm:mt-20 sm:px-8" aria-labelledby="news-feed-heading">
  <div class="border-4 border-[#0a0a0a] bg-[#0a0a0a] p-2 shadow-[8px_8px_0_#cc0000] sm:p-3 sm:shadow-[12px_12px_0_#cc0000]">
    <header class="flex flex-col gap-3 bg-[#ffd400] px-4 py-4 sm:flex-row sm:items-end sm:justify-between sm:px-6">
      <div>
        <p class="font-black uppercase tracking-[0.18em] text-[#cc0000]">Fiat, inflation &amp; FX</p>
        <h2 id="news-feed-heading" class="font-display text-4xl font-black leading-none sm:text-5xl">The money wire</h2>
      </div>
      <p class="max-w-md text-sm font-bold leading-snug text-[#444] sm:text-right">
        Latest dispatches from central banks, official data sources, and financial news wires.
      </p>
    </header>

    <% if articles.any? %>
      <ol class="grid gap-2 bg-[#0a0a0a] pt-2 md:grid-cols-2 lg:grid-cols-3">
        <% articles.each_with_index do |article, index| %>
          <li class="group relative flex min-h-64 flex-col bg-white p-5 transition duration-150 hover:-translate-y-1 hover:bg-[#faf7f2] focus-within:-translate-y-1 sm:p-6">
            <div class="mb-5 flex items-start justify-between gap-3">
              <span class="inline-block bg-[#1a56db] px-2 py-1 text-xs font-black uppercase tracking-wide text-white">
                <%= article.publisher.presence || article.provider.humanize %>
              </span>
              <span class="font-display text-3xl font-black leading-none text-[#cc0000]" aria-hidden="true"><%= format("%02d", index + 1) %></span>
            </div>

            <h3 class="font-display text-2xl font-black leading-tight text-[#0a0a0a] group-hover:text-[#cc0000]">
              <%= link_to article.headline, article.canonical_url,
                    class: "after:absolute after:inset-0 focus:outline-none focus-visible:outline focus-visible:outline-4 focus-visible:outline-offset-[-4px] focus-visible:outline-[#1a56db]",
                    target: "_blank", rel: "noopener noreferrer nofollow" %>
            </h3>

            <% if article.summary.present? %>
              <p class="mt-3 line-clamp-3 text-sm font-semibold leading-relaxed text-[#444]"><%= truncate(article.summary, length: 180) %></p>
            <% end %>

            <div class="mt-auto flex flex-wrap items-end justify-between gap-3 pt-6 text-xs font-black uppercase tracking-wide text-[#444]">
              <time datetime="<%= article.published_at.iso8601 %>" title="<%= article.published_at.to_fs(:long) %>">
                <%= time_ago_in_words(article.published_at) %> ago
              </time>
              <% if article.topics.any? %>
                <span class="relative z-10 bg-[#ffd400] px-2 py-1 text-[#0a0a0a]"><%= article.topics.first.humanize %></span>
              <% end %>
            </div>
          </li>
        <% end %>
      </ol>
    <% else %>
      <div class="bg-white px-5 py-10 text-center sm:px-8 sm:py-14">
        <p class="font-display text-3xl font-black text-[#0a0a0a]">The wire is warming up.</p>
        <p class="mx-auto mt-2 max-w-xl font-semibold text-[#444]">Fresh money news will appear here after the first scheduled source refresh.</p>
      </div>
    <% end %>
  </div>
</section>
