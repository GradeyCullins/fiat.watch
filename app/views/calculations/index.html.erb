<% content_for :head do %>
  <script type="application/ld+json"><%= raw({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Fiat Watch",
    "url": request.base_url,
    "applicationCategory": "FinanceApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
    "description": "Free inflation calculator using US BLS CPI-U data. Convert any dollar amount from one year to another."
  }.to_json) %></script>

  <script type="application/ld+json"><%= raw({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How is inflation calculated?",
        "acceptedAnswer": { "@type": "Answer", "text": "We use the Consumer Price Index for All Urban Consumers (CPI-U) published by the U.S. Bureau of Labor Statistics. The conversion is amount × (CPI_end ÷ CPI_start)." }
      },
      {
        "@type": "Question",
        "name": "What years are supported?",
        "acceptedAnswer": { "@type": "Answer", "text": "Annual averages from #{CpiCalculator.earliest_year} through #{CpiCalculator.latest_year}, with the latest published monthly CPI used for the current year when its annual average is not available yet." }
      },
      {
        "@type": "Question",
        "name": "Is this data official?",
        "acceptedAnswer": { "@type": "Answer", "text": "Yes — it comes directly from the U.S. Bureau of Labor Statistics CPI-U series (CUUR0000SA0)." }
      }
    ]
  }.to_json) %></script>

  <style>
    @keyframes fiat-ticker-scroll {
      from {
        transform: translate3d(0, 0, 0);
      }

      to {
        transform: translate3d(-50%, 0, 0);
      }
    }

    .fiat-ticker {
      contain: paint;
      margin-left: calc(50% - 50vw);
      margin-right: calc(50% - 50vw);
      width: 100vw;
    }

    .fiat-ticker-mask {
      -webkit-mask-image: linear-gradient(90deg, transparent, #000 5%, #000 95%, transparent);
      mask-image: linear-gradient(90deg, transparent, #000 5%, #000 95%, transparent);
      overflow: hidden;
    }

    .fiat-ticker-track {
      animation: fiat-ticker-scroll 34s linear infinite;
      display: flex;
      gap: 0.75rem;
      width: max-content;
      will-change: transform;
    }

    .fiat-ticker:hover .fiat-ticker-track {
      animation-play-state: paused;
    }

    @media (max-width: 640px) {
      .fiat-ticker-mask {
        margin-inline: -1.25rem;
      }

      .fiat-ticker-track {
        animation-duration: 26s;
        gap: 0.5rem;
      }

      .fiat-ticker-card {
        min-width: 12.5rem;
      }
    }

    @media (prefers-reduced-motion: reduce) {
      .fiat-ticker-mask {
        -webkit-mask-image: none;
        mask-image: none;
        overflow-x: auto;
      }

      .fiat-ticker-track {
        animation: none;
      }
    }
  </style>
<% end %>

<section class="mx-auto grid w-full max-w-7xl gap-8 px-5 pb-10 pt-2 sm:px-8 sm:pt-5 lg:min-h-[calc(100svh-9rem)] lg:grid-cols-[minmax(0,0.82fr)_minmax(32rem,1.18fr)] lg:items-center lg:gap-12 lg:py-8" aria-labelledby="hero-heading">
  <div class="order-2 lg:order-1">
    <p class="inline-flex -rotate-1 items-center gap-2 border-4 border-[#0a0a0a] bg-[#ffd400] px-3 py-2 text-xs font-black uppercase tracking-wide text-[#0a0a0a] shadow-[5px_5px_0_#0a0a0a] sm:text-sm">
      <span class="inline-block size-2.5 bg-[#cc0000]" aria-hidden="true"></span>
      Official CPI-U data · <%= CpiCalculator.earliest_year %>–<%= CpiCalculator.latest_year %>
    </p>
    <h1 id="hero-heading" class="mt-5 max-w-2xl font-display text-5xl font-black leading-[0.9] text-[#0a0a0a] sm:text-7xl lg:text-7xl xl:text-8xl">
      What was your money
      <span class="relative mt-2 inline-block -rotate-1 bg-[#cc0000] px-3 py-1 text-white shadow-[8px_8px_0_#0a0a0a] sm:px-4">really worth?</span>
    </h1>
    <p class="mt-7 max-w-xl text-lg font-bold leading-snug text-[#444] sm:text-xl">
      Compare the buying power of any US dollar amount across more than a century. Pick two years and get the answer instantly.
    </p>
  </div>

  <section id="calculator-panel" class="order-1 overflow-visible border-4 border-[#0a0a0a] bg-white shadow-[9px_9px_0_#cc0000] [overflow-anchor:none] sm:shadow-[12px_12px_0_#cc0000] lg:order-2" aria-labelledby="calc-heading">
    <div class="flex items-center justify-between gap-4 border-b-4 border-[#0a0a0a] bg-[#0a0a0a] px-4 py-3 text-white sm:px-5">
      <div>
        <p class="text-xs font-black uppercase tracking-[0.18em] text-[#ffd400]">Purchasing power</p>
        <h2 id="calc-heading" class="font-display text-2xl font-black leading-none sm:text-3xl">Inflation calculator</h2>
      </div>
      <span class="shrink-0 border-2 border-white bg-[#1a56db] px-2 py-1 text-xs font-black uppercase text-white shadow-[3px_3px_0_#ffd400]">CPI-U</span>
    </div>

    <%= turbo_frame_tag "result", class: "block empty:hidden" do %>
      <%= render "result" %>
    <% end %>

    <%= form_with url: calculation_path, method: :get, data: { turbo_frame: "result", turbo_action: "advance" }, class: "p-4 sm:p-5" do |f| %>
      <div class="grid grid-cols-2 gap-3 sm:grid-cols-[minmax(0,1.2fr)_minmax(8rem,0.65fr)_minmax(8rem,0.65fr)] sm:gap-4">
        <div class="col-span-2 flex flex-col gap-1.5 sm:col-span-1">
          <%= f.label :amount, "Amount", class: "text-xs font-black uppercase tracking-wide text-[#444]" %>
          <div class="relative">
            <span class="pointer-events-none absolute left-3 top-1/2 -translate-y-1/2 font-display text-3xl font-black text-[#cc0000]" aria-hidden="true">$</span>
            <%= f.number_field :amount, value: @amount || 100, min: 0.01, step: "any", required: true, inputmode: "decimal", autocomplete: "off", class: "min-h-14 w-full border-4 border-[#0a0a0a] bg-[#faf7f2] py-2 pl-9 pr-3 font-display text-3xl font-black leading-none text-[#cc0000] outline-none focus:-translate-x-0.5 focus:-translate-y-0.5 focus:shadow-[6px_6px_0_#1a56db] sm:text-4xl", aria: { label: "Amount in US dollars" } %>
          </div>
        </div>

        <div class="flex min-w-0 flex-col gap-1.5">
          <%= f.label :from_year, "From year", class: "text-xs font-black uppercase tracking-wide text-[#444]" %>
          <%= f.select :from_year, options_for_select(@year_options.map { |y| [y, y] }, @from_year), {}, class: "min-h-14 w-full border-4 border-[#0a0a0a] bg-[#ffd400] px-2 py-2 font-display text-2xl font-black leading-none text-[#0a0a0a] outline-none focus:-translate-x-0.5 focus:-translate-y-0.5 focus:shadow-[6px_6px_0_#1a56db] sm:px-3 sm:text-3xl" %>
        </div>

        <div class="flex min-w-0 flex-col gap-1.5">
          <%= f.label :to_year, "To year", class: "text-xs font-black uppercase tracking-wide text-[#444]" %>
          <%= f.select :to_year, options_for_select(@year_options.map { |y| [y, y] }, @to_year), {}, class: "min-h-14 w-full border-4 border-[#0a0a0a] bg-[#ffd400] px-2 py-2 font-display text-2xl font-black leading-none text-[#0a0a0a] outline-none focus:-translate-x-0.5 focus:-translate-y-0.5 focus:shadow-[6px_6px_0_#1a56db] sm:px-3 sm:text-3xl" %>
        </div>
      </div>

      <button type="submit" class="mt-4 flex min-h-14 w-full items-center justify-center gap-3 border-4 border-[#0a0a0a] bg-[#cc0000] px-5 py-2 font-display text-2xl font-black uppercase text-white shadow-[7px_7px_0_#1a56db] transition duration-150 ease-out hover:-translate-x-0.5 hover:-translate-y-0.5 hover:bg-[#0a0a0a] hover:text-[#ffd400] hover:shadow-[9px_9px_0_#1a56db] focus:outline-none focus-visible:outline focus-visible:outline-4 focus-visible:outline-offset-4 focus-visible:outline-[#1a56db] active:translate-x-0 active:translate-y-0 active:bg-[#1a56db] active:shadow-[4px_4px_0_#ffd400]">
        Calculate
        <span aria-hidden="true">&rarr;</span>
      </button>
    <% end %>
  </section>
</section>

<div class="fiat-ticker mb-12" aria-label="CPI purchasing power ticker">
  <p class="sr-only">
    CPI purchasing power examples:
    <% @ticker_items.each do |item| %>
      <%= item.fetch(:from_text) %> equals <%= item.fetch(:to_text) %>.
    <% end %>
  </p>
  <div class="border-y-2 border-[#0a0a0a] bg-[#ffd400] py-1 shadow-[0_4px_0_#0a0a0a] sm:border-y-4 sm:shadow-[0_5px_0_#cc0000]">
    <div class="flex items-center gap-2 border-y-2 border-[#0a0a0a] bg-[#0a0a0a] px-3 py-1.5 text-white sm:gap-3 sm:px-5">
      <span class="shrink-0 bg-[#cc0000] px-2 py-1 font-display text-xs font-black uppercase leading-none text-white shadow-[2px_2px_0_#ffd400]">CPI-U tape</span>
      <div class="fiat-ticker-mask min-w-0 flex-1" aria-hidden="true">
        <div class="fiat-ticker-track">
          <% 2.times do %>
            <% @ticker_items.each do |item| %>
              <div class="fiat-ticker-card flex shrink-0 items-center gap-1.5 whitespace-nowrap border-2 border-[#0a0a0a] bg-white px-2 py-1 text-[#0a0a0a] shadow-[3px_3px_0_#1a56db] sm:gap-2 sm:px-3 sm:py-1.5">
                <span class="bg-[#ffd400] px-1.5 py-0.5 text-[0.625rem] font-black uppercase leading-none text-[#0a0a0a] sm:px-2"><%= item.fetch(:label) %></span>
                <span class="font-display text-base font-black leading-none sm:text-lg"><%= item.fetch(:from_text) %></span>
                <span class="font-display text-lg font-black leading-none text-[#cc0000]" aria-hidden="true">&rarr;</span>
                <span class="font-display text-base font-black leading-none text-[#1a56db] sm:text-lg"><%= item.fetch(:to_text) %></span>
              </div>
            <% end %>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>

<section class="mx-auto max-w-3xl px-5 text-lg font-semibold leading-relaxed text-[#0a0a0a] sm:px-8">
  <h2 class="mb-4 mt-10 font-display text-4xl font-black text-[#cc0000]">How the Fiat Watch inflation calculator works</h2>
  <p class="mt-4">
    Inflation erodes the value of money over time. A dollar in <%= CpiCalculator.earliest_year %> bought a
    lot more bread, gasoline, and rent than a dollar today. To compare prices across years
    fairly, we use the Consumer Price Index — a basket of goods the
    U.S. Bureau of Labor Statistics has been tracking since 1913.
  </p>
  <p class="mt-4">
    The math is simple:
    <code class="bg-[#ffd400] px-2 py-1 font-mono text-base font-black">converted = amount × (CPI<sub>target</sub> ÷ CPI<sub>start</sub>)</code>.
    We use the annual averages of the CPI-U (All Urban Consumers, series CUUR0000SA0) so the
    result reflects a typical year, not a single noisy month.
  </p>

  <h2 class="mb-4 mt-10 font-display text-4xl font-black text-[#cc0000]">Popular CPI calculators</h2>
  <p class="mt-4">
    For common budget questions, use a focused calculator with examples for that cost category.
  </p>
  <ul class="mt-5 grid gap-3 sm:grid-cols-2">
    <% calculator_page_links.each do |label, path| %>
      <li>
        <a class="block border-4 border-[#0a0a0a] bg-white px-4 py-3 font-black text-[#0a0a0a] shadow-[5px_5px_0_#ffd400] hover:-translate-x-1 hover:-translate-y-1 hover:text-[#cc0000] focus:-translate-x-1 focus:-translate-y-1 focus:outline-none" href="<%= path %>"><%= label %></a>
      </li>
    <% end %>
  </ul>

  <h2 class="mb-4 mt-10 font-display text-4xl font-black text-[#cc0000]">Historical prices</h2>
  <p class="mt-4">
    Browse BLS average prices by item, then open year-specific pages for inflation-adjusted comparisons.
  </p>
  <ul class="mt-5 grid gap-3 sm:grid-cols-2">
    <% historical_price_links.each do |label, path| %>
      <li>
        <a class="block border-4 border-[#0a0a0a] bg-white px-4 py-3 font-black text-[#0a0a0a] shadow-[5px_5px_0_#ffd400] hover:-translate-x-1 hover:-translate-y-1 hover:text-[#cc0000] focus:-translate-x-1 focus:-translate-y-1 focus:outline-none" href="<%= path %>"><%= label %></a>
      </li>
    <% end %>
  </ul>

  <h2 class="mb-4 mt-10 font-display text-4xl font-black text-[#cc0000]">Frequently asked questions</h2>
  <dl>
    <dt class="mt-5 font-black">What years are supported?</dt>
    <dd class="mt-2 text-[#444]">
      Annual averages from <%= CpiCalculator.earliest_year %> through <%= CpiCalculator.latest_year %>.
      <% if CpiCalculator.provisional_year?(CpiCalculator.latest_year) %>
        <%= CpiCalculator.provisional_year_note(CpiCalculator.latest_year) %>
      <% end %>
    </dd>
    <dt class="mt-5 font-black">Why do my answers differ slightly from other calculators?</dt>
    <dd class="mt-2 text-[#444]">Most calculators use annual averages, but a few use specific months (often December or January). We use annual averages — the same approach the BLS recommends for long-horizon comparisons.</dd>
    <dt class="mt-5 font-black">Where does the data come from?</dt>
    <dd class="mt-2 text-[#444]">Directly from the U.S. Bureau of Labor Statistics. The dataset bundled with this site is refreshable via a single Rake task that hits the public BLS API.</dd>
  </dl>
</section>
