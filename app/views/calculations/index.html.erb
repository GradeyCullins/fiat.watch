<% content_for :head do %>
  <script type="application/ld+json"><%= raw({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Fiat Watch",
    "url": request.base_url,
    "applicationCategory": "FinanceApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
    "description": "Free inflation calculator using US BLS CPI-U data. Convert any dollar amount from one year to another."
  }.to_json) %></script>

  <script type="application/ld+json"><%= raw({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How is inflation calculated?",
        "acceptedAnswer": { "@type": "Answer", "text": "We use the Consumer Price Index for All Urban Consumers (CPI-U) published by the U.S. Bureau of Labor Statistics. The conversion is amount × (CPI_end ÷ CPI_start)." }
      },
      {
        "@type": "Question",
        "name": "What years are supported?",
        "acceptedAnswer": { "@type": "Answer", "text": "Annual averages from #{CpiCalculator.earliest_year} through #{CpiCalculator.latest_year}, with the latest published monthly CPI used for the current year when its annual average is not available yet." }
      },
      {
        "@type": "Question",
        "name": "Is this data official?",
        "acceptedAnswer": { "@type": "Answer", "text": "Yes — it comes directly from the U.S. Bureau of Labor Statistics CPI-U series (CUUR0000SA0)." }
      }
    ]
  }.to_json) %></script>

  <style>
    @keyframes fiat-ticker-scroll {
      from {
        transform: translate3d(0, 0, 0);
      }

      to {
        transform: translate3d(-50%, 0, 0);
      }
    }

    .fiat-ticker {
      contain: paint;
      margin-left: calc(50% - 50vw);
      margin-right: calc(50% - 50vw);
      width: 100vw;
    }

    .fiat-ticker-mask {
      -webkit-mask-image: linear-gradient(90deg, transparent, #000 5%, #000 95%, transparent);
      mask-image: linear-gradient(90deg, transparent, #000 5%, #000 95%, transparent);
      overflow: hidden;
    }

    .fiat-ticker-track {
      animation: fiat-ticker-scroll 34s linear infinite;
      display: flex;
      gap: 0.75rem;
      width: max-content;
      will-change: transform;
    }

    .fiat-ticker:hover .fiat-ticker-track {
      animation-play-state: paused;
    }

    @media (max-width: 640px) {
      .fiat-ticker-mask {
        margin-inline: -1.25rem;
      }

      .fiat-ticker-track {
        animation-duration: 26s;
        gap: 0.5rem;
      }

      .fiat-ticker-card {
        min-width: 12.5rem;
      }
    }

    @media (prefers-reduced-motion: reduce) {
      .fiat-ticker-mask {
        -webkit-mask-image: none;
        mask-image: none;
        overflow-x: auto;
      }

      .fiat-ticker-track {
        animation: none;
      }
    }
  </style>
<% end %>

<section class="mx-auto grid w-full max-w-7xl gap-6 px-5 py-4 sm:px-8 sm:py-6 lg:grid-cols-[0.82fr_1fr] lg:items-start lg:gap-10 lg:py-10" aria-labelledby="calc-heading">
  <div class="fiat-ticker order-1 lg:col-span-2" aria-label="CPI purchasing power ticker">
    <p class="sr-only">
      CPI purchasing power examples:
      <% @ticker_items.each do |item| %>
        <%= item.fetch(:from_text) %> equals <%= item.fetch(:to_text) %>.
      <% end %>
    </p>
    <div class="border-y-2 border-[#0a0a0a] bg-[#ffd400] py-1 shadow-[0_4px_0_#0a0a0a] sm:border-y-4 sm:shadow-[0_5px_0_#cc0000]">
      <div class="flex items-center gap-2 border-y-2 border-[#0a0a0a] bg-[#0a0a0a] px-3 py-1.5 text-white sm:gap-3 sm:px-5">
        <span class="shrink-0 bg-[#cc0000] px-2 py-1 font-display text-xs font-black uppercase leading-none text-white shadow-[2px_2px_0_#ffd400]">CPI-U tape</span>
        <div class="fiat-ticker-mask min-w-0 flex-1" aria-hidden="true">
          <div class="fiat-ticker-track">
            <% 2.times do %>
              <% @ticker_items.each do |item| %>
                <div class="fiat-ticker-card flex shrink-0 items-center gap-1.5 whitespace-nowrap border-2 border-[#0a0a0a] bg-white px-2 py-1 text-[#0a0a0a] shadow-[3px_3px_0_#1a56db] sm:gap-2 sm:px-3 sm:py-1.5">
                  <span class="bg-[#ffd400] px-1.5 py-0.5 text-[0.625rem] font-black uppercase leading-none text-[#0a0a0a] sm:px-2"><%= item.fetch(:label) %></span>
                  <span class="font-display text-base font-black leading-none sm:text-lg"><%= item.fetch(:from_text) %></span>
                  <span class="font-display text-lg font-black leading-none text-[#cc0000]" aria-hidden="true">&rarr;</span>
                  <span class="font-display text-base font-black leading-none text-[#1a56db] sm:text-lg"><%= item.fetch(:to_text) %></span>
                </div>
              <% end %>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="order-2 lg:order-1">
    <h1 class="flex flex-col gap-2 font-display text-4xl font-black leading-[0.94] sm:text-6xl lg:text-7xl xl:text-8xl">
      <span data-controller="hover-tilt" data-hover-tilt-max-value="6" data-hover-tilt-lift-value="3" class="inline-block w-fit -rotate-1 bg-[#cc0000] px-3 py-1.5 text-white shadow-[7px_7px_0_#0a0a0a] sm:px-4 sm:py-2 sm:shadow-[9px_9px_0_#0a0a0a]">Spending</span>
      <span data-controller="hover-tilt" data-hover-tilt-max-value="6" data-hover-tilt-lift-value="3" class="ml-3 inline-block w-fit rotate-1 bg-[#ffd400] px-3 py-1.5 text-[#0a0a0a] shadow-[7px_7px_0_#0a0a0a] sm:ml-10 sm:px-4 sm:py-2 sm:shadow-[9px_9px_0_#0a0a0a] lg:ml-8">$X in <em>year A</em></span>
      <span data-controller="hover-tilt" data-hover-tilt-max-value="6" data-hover-tilt-lift-value="3" class="inline-block w-fit -rotate-1 bg-[#1a56db] px-3 py-1.5 text-white shadow-[7px_7px_0_#0a0a0a] sm:px-4 sm:py-2 sm:shadow-[9px_9px_0_#0a0a0a]">is like spending</span>
      <span data-controller="hover-tilt" data-hover-tilt-max-value="6" data-hover-tilt-lift-value="3" class="ml-2 inline-block w-fit rotate-1 bg-[#0a0a0a] px-3 py-1.5 text-[#ffd400] shadow-[7px_7px_0_#cc0000] sm:ml-16 sm:px-4 sm:py-2 sm:shadow-[9px_9px_0_#cc0000] lg:ml-12">$Y in <em>year B</em>.</span>
    </h1>
    <p data-controller="hover-tilt" data-hover-tilt-max-value="5" data-hover-tilt-lift-value="5" class="mt-6 max-w-xl rotate-1 border-4 border-[#0a0a0a] bg-white p-4 text-lg font-bold leading-snug shadow-[8px_8px_0_#1a56db] sm:p-5 sm:text-xl sm:shadow-[10px_10px_0_#1a56db]">
      Pick a year, pick an amount. We crunch official BLS Consumer Price Index data
      and show you what those dollars are really worth today (or any other year you choose).
    </p>
  </div>

  <div class="order-1 lg:order-2">
    <h2 id="calc-heading" class="sr-only">Inflation calculator</h2>

    <%= form_with url: calculation_path, method: :get, data: { turbo_frame: "result", turbo_action: "advance", controller: "hover-tilt", hover_tilt_max_value: 4, hover_tilt_lift_value: 6, hover_tilt_perspective_value: 900 }, class: "rounded-none border-4 border-[#0a0a0a] bg-white p-4 shadow-[8px_8px_0_#cc0000] sm:p-6 sm:shadow-[12px_12px_0_#cc0000] lg:p-8" do |f| %>
    <div class="grid gap-4 sm:grid-cols-[minmax(0,1.35fr)_minmax(10rem,0.65fr)] sm:items-end">
      <div class="flex flex-col gap-2">
        <%= f.label :amount, "Amount", class: "text-sm font-black uppercase text-[#444]" %>
        <div class="relative">
          <span class="pointer-events-none absolute left-4 top-1/2 -translate-y-1/2 font-display text-4xl font-black text-[#cc0000] sm:text-5xl" aria-hidden="true">$</span>
          <%= f.number_field :amount, value: @amount || 100, min: 0.01, step: "any", required: true, inputmode: "decimal", autocomplete: "off", class: "w-full border-4 border-[#0a0a0a] bg-[#faf7f2] py-3 pl-11 pr-4 font-display text-4xl font-black leading-none text-[#cc0000] outline-none focus:-translate-x-1 focus:-translate-y-1 focus:shadow-[9px_9px_0_#1a56db] sm:pl-12 sm:text-5xl", aria: { label: "Amount in US dollars" } %>
        </div>
      </div>

      <div class="flex flex-col gap-2">
        <%= f.label :from_year, "in year", class: "text-sm font-black uppercase text-[#444]" %>
        <%= f.select :from_year, options_for_select(@year_options.map { |y| [y, y] }, @from_year), {}, class: "w-full border-4 border-[#0a0a0a] bg-[#ffd400] px-4 py-3 font-display text-4xl font-black leading-none text-[#0a0a0a] outline-none focus:-translate-x-1 focus:-translate-y-1 focus:shadow-[9px_9px_0_#1a56db] sm:text-5xl" %>
      </div>
    </div>

    <p class="my-4 font-display text-2xl font-black italic text-[#444] sm:my-5 sm:text-3xl">is like spending&hellip;</p>

    <div class="grid gap-4 sm:grid-cols-[minmax(10rem,0.65fr)_1fr] sm:items-end">
      <div class="flex flex-col gap-2">
        <%= f.label :to_year, "in year", class: "text-sm font-black uppercase text-[#444]" %>
        <%= f.select :to_year, options_for_select(@year_options.map { |y| [y, y] }, @to_year), {}, class: "w-full border-4 border-[#0a0a0a] bg-[#ffd400] px-4 py-3 font-display text-4xl font-black leading-none text-[#0a0a0a] outline-none focus:-translate-x-1 focus:-translate-y-1 focus:shadow-[9px_9px_0_#1a56db] sm:text-5xl" %>
      </div>
    </div>

    <button type="submit" data-hover-tilt-ignore class="mt-5 w-full border-4 border-[#0a0a0a] bg-[#0a0a0a] px-6 py-3 font-display text-2xl font-black uppercase text-[#ffd400] shadow-[8px_8px_0_#1a56db] transition duration-150 ease-out hover:bg-[#cc0000] hover:text-white hover:shadow-[11px_11px_0_#1a56db] focus:outline-none focus-visible:outline focus-visible:outline-4 focus-visible:outline-offset-4 focus-visible:outline-[#1a56db] focus-visible:shadow-[11px_11px_0_#cc0000] active:bg-[#1a56db] active:shadow-[5px_5px_0_#cc0000] sm:mt-6 sm:w-auto sm:px-8 sm:py-4 sm:text-3xl sm:shadow-[10px_10px_0_#1a56db] sm:hover:shadow-[13px_13px_0_#1a56db] sm:focus-visible:shadow-[13px_13px_0_#cc0000]">
      Calculate
    </button>
    <% end %>

    <%= turbo_frame_tag "result", class: "mt-8 block" do %>
      <%= render "result" %>
    <% end %>
  </div>
</section>

<section class="mx-auto mt-20 max-w-3xl px-5 text-lg font-semibold leading-relaxed text-[#0a0a0a] sm:px-8">
  <h2 class="mb-4 mt-10 font-display text-4xl font-black text-[#cc0000]">How the Fiat Watch inflation calculator works</h2>
  <p class="mt-4">
    Inflation erodes the value of money over time. A dollar in <%= CpiCalculator.earliest_year %> bought a
    lot more bread, gasoline, and rent than a dollar today. To compare prices across years
    fairly, we use the Consumer Price Index — a basket of goods the
    U.S. Bureau of Labor Statistics has been tracking since 1913.
  </p>
  <p class="mt-4">
    The math is simple:
    <code class="bg-[#ffd400] px-2 py-1 font-mono text-base font-black">converted = amount × (CPI<sub>target</sub> ÷ CPI<sub>start</sub>)</code>.
    We use the annual averages of the CPI-U (All Urban Consumers, series CUUR0000SA0) so the
    result reflects a typical year, not a single noisy month.
  </p>

  <h2 class="mb-4 mt-10 font-display text-4xl font-black text-[#cc0000]">Frequently asked questions</h2>
  <dl>
    <dt class="mt-5 font-black">What years are supported?</dt>
    <dd class="mt-2 text-[#444]">
      Annual averages from <%= CpiCalculator.earliest_year %> through <%= CpiCalculator.latest_year %>.
      <% if CpiCalculator.provisional_year?(CpiCalculator.latest_year) %>
        <%= CpiCalculator.provisional_year_note(CpiCalculator.latest_year) %>
      <% end %>
    </dd>
    <dt class="mt-5 font-black">Why do my answers differ slightly from other calculators?</dt>
    <dd class="mt-2 text-[#444]">Most calculators use annual averages, but a few use specific months (often December or January). We use annual averages — the same approach the BLS recommends for long-horizon comparisons.</dd>
    <dt class="mt-5 font-black">Where does the data come from?</dt>
    <dd class="mt-2 text-[#444]">Directly from the U.S. Bureau of Labor Statistics. The dataset bundled with this site is refreshable via a single Rake task that hits the public BLS API.</dd>
  </dl>
</section>
