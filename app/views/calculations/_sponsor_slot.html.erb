<aside
  class="mt-8 border-4 border-[#0a0a0a] bg-white p-5 shadow-[10px_10px_0_#cc0000] sm:p-6"
  aria-label="Advertising"
  data-controller="analytics"
  data-analytics-event-name-value="sponsor_slot_view"
  data-analytics-params-value="<%= { placement: "calculation_result" }.to_json %>"
>
  <p class="text-xs font-black uppercase tracking-wide text-[#444]">Sponsor</p>
  <div class="mt-3 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
    <div>
      <p class="font-display text-3xl font-black leading-none text-[#0a0a0a]">Your ad here</p>
      <p class="mt-2 max-w-2xl font-semibold text-[#444]">Reach people comparing salaries, rent, groceries, and purchasing power.</p>
    </div>
    <a
      class="inline-flex w-fit border-4 border-[#0a0a0a] bg-[#1a56db] px-5 py-3 font-display text-xl font-black uppercase text-white shadow-[7px_7px_0_#ffd400] hover:-translate-x-1 hover:-translate-y-1 focus:-translate-x-1 focus:-translate-y-1 focus:outline-none"
      href="mailto:ads@cookedfiat.com?subject=Cooked%20Fiat%20advertising"
      data-controller="analytics"
      data-analytics-track-on-connect-value="false"
      data-analytics-event-name-value="sponsor_contact_click"
      data-analytics-params-value="<%= { placement: "calculation_result" }.to_json %>"
      data-action="click->analytics#track"
    >Advertise</a>
  </div>
</aside>
