<section class="mx-auto grid w-full max-w-7xl gap-8 px-5 py-8 sm:px-8 lg:grid-cols-[1.05fr_0.95fr] lg:items-end lg:py-12">
  <div>
    <p class="w-fit -rotate-1 bg-[#ffd400] px-3 py-2 font-display text-xl font-black uppercase text-[#0a0a0a] shadow-[6px_6px_0_#0a0a0a]">Cooked Fiat</p>
    <h1 class="mt-6 max-w-4xl font-display text-6xl font-black leading-[0.92] text-[#cc0000] sm:text-7xl lg:text-8xl"><%= @page.fetch(:heading) %></h1>
  </div>
  <p class="max-w-xl border-4 border-[#0a0a0a] bg-white p-5 text-xl font-bold leading-snug shadow-[10px_10px_0_#1a56db] rotate-1">
    <%= @page.fetch(:intro) %>
  </p>
</section>

<section class="mx-auto w-full max-w-7xl px-5 py-8 sm:px-8">
  <div class="grid gap-8 lg:grid-cols-[0.9fr_1.1fr] lg:items-start">
    <div class="border-4 border-[#0a0a0a] bg-white p-5 shadow-[10px_10px_0_#cc0000] sm:p-8">
      <h2 class="font-display text-4xl font-black text-[#0a0a0a]">Compare any amount</h2>
      <p class="mt-4 text-lg font-semibold leading-relaxed text-[#444]">
        The calculator uses annual CPI-U data from the U.S. Bureau of Labor Statistics. Enter an amount and two years to see the equivalent purchasing power.
      </p>
      <a class="mt-6 inline-flex border-4 border-[#0a0a0a] bg-[#0a0a0a] px-6 py-4 font-display text-2xl font-black uppercase text-[#ffd400] shadow-[8px_8px_0_#1a56db] hover:-translate-x-1 hover:-translate-y-1 focus:-translate-x-1 focus:-translate-y-1 focus:outline-none" href="/#calc-heading">Open calculator</a>
    </div>

    <div class="border-4 border-[#0a0a0a] bg-[#ffd400] p-5 shadow-[10px_10px_0_#1a56db] sm:p-8">
      <h2 class="font-display text-4xl font-black text-[#cc0000]">Common searches</h2>
      <ul class="mt-5 grid gap-3 text-lg font-black text-[#0a0a0a] sm:grid-cols-3">
        <% @page.fetch(:examples).each do |example| %>
          <li class="border-4 border-[#0a0a0a] bg-white px-4 py-3 shadow-[5px_5px_0_#0a0a0a]"><%= example %></li>
        <% end %>
      </ul>
      <p class="mt-6 text-lg font-semibold leading-relaxed text-[#444]">
        These examples use the same CPI conversion formula as every Cooked Fiat result: amount times target-year CPI divided by start-year CPI.
      </p>
    </div>
  </div>
</section>
