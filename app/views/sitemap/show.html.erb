<section class="mx-auto w-full max-w-7xl px-5 py-8 sm:px-8">
  <div class="max-w-4xl">
    <p class="w-fit -rotate-1 bg-[#ffd400] px-3 py-2 font-display text-base font-black uppercase text-[#0a0a0a] shadow-[5px_5px_0_#0a0a0a] sm:text-xl">Sitemap</p>
    <h1 class="mt-5 font-display text-5xl font-black leading-[0.94] text-[#cc0000] sm:text-7xl">Cooked Fiat sitemap</h1>
    <p class="mt-5 text-xl font-black leading-snug text-[#0a0a0a] sm:text-2xl">Browse the main calculator, SEO calculators, and historical cost pages.</p>
  </div>

  <div class="mt-8 grid gap-6 lg:grid-cols-[0.85fr_1.15fr]">
    <section class="border-4 border-[#0a0a0a] bg-white p-5 shadow-[10px_10px_0_#1a56db] sm:p-6">
      <h2 class="font-display text-4xl font-black text-[#0a0a0a]">Calculators</h2>
      <ul class="mt-5 grid gap-3 text-lg font-black">
        <li>
          <a class="text-[#1a56db] underline decoration-2 underline-offset-4 hover:text-[#cc0000]" href="/">US inflation calculator</a>
        </li>
        <% @calculator_pages.each do |label, path| %>
          <li>
            <a class="text-[#1a56db] underline decoration-2 underline-offset-4 hover:text-[#cc0000]" href="<%= path %>"><%= label %></a>
          </li>
        <% end %>
      </ul>
      <p class="mt-6 text-sm font-bold text-[#555]">
        Machine-readable sitemap: <a class="text-[#1a56db] underline decoration-2 underline-offset-4" href="<%= sitemap_path %>">sitemap.xml</a>
      </p>
    </section>

    <section class="border-4 border-[#0a0a0a] bg-[#ffd400] p-5 shadow-[10px_10px_0_#cc0000] sm:p-6">
      <h2 class="font-display text-4xl font-black text-[#0a0a0a]">Historical costs</h2>
      <div class="mt-5 grid gap-5 sm:grid-cols-2">
        <% @cost_pages.each do |item, entries| %>
          <div>
            <h3 class="font-display text-2xl font-black text-[#cc0000]"><%= item.question_name.capitalize %></h3>
            <ul class="mt-3 flex flex-wrap gap-2 text-base font-black">
              <% entries.each do |_entry_item, year, _price| %>
                <li>
                  <a class="inline-flex border-4 border-[#0a0a0a] bg-white px-3 py-2 shadow-[4px_4px_0_#0a0a0a] hover:-translate-x-1 hover:-translate-y-1 focus:-translate-x-1 focus:-translate-y-1 focus:outline-none" href="<%= cost_page_path(item.slug, year) %>"><%= year %></a>
                </li>
              <% end %>
            </ul>
          </div>
        <% end %>
      </div>
    </section>
  </div>
</section>
